# Copy to .env and fill in API keys. Server-side only; the web UI does not read these.

# --- Docker note ---
# The Dockerfile sets EDITR_DB_PATH=/app/data/editr.sqlite and docker-compose mounts ./data -> /app/data.
# Do not copy a bare-metal .env into `docker run --env-file` if it still has EDITR_DB_PATH=editr.sqlite:
# SQLite would land under /app outside the volume. For Docker, omit EDITR_DB_PATH or set EDITR_DB_PATH=/app/data/editr.sqlite.

EDITR_DB_PATH=editr.sqlite
# Optional: directory with a Vite/React build (index.html + assets). Unset = API-only.
# EDITR_STATIC_DIR=
# Optional: override directory for PET_SOUL.md and stories/{document_id}.md (default: <repo>/docs/pet)
# EDITR_PET_SOUL_DIR=
# Tests / dev: skip background persona_refresh after full analyze (avoids SQLite file locks on Windows)
# EDITR_DISABLE_PERSONA_REFRESH=1
# Story-chat: document memory jobs + persona paragraph digest (set to 1 to disable scheduling)
# EDITR_DISABLE_INKBLOT_MEMORY_JOBS=1
# EDITR_INKBLOT_MEMORY_BATCH_USER_TURNS=5
# EDITR_INKBLOT_PERSONA_DIGEST_USER_TURNS=5
# EDITR_INKBLOT_MEMORY_TRANSCRIPT_MAX_CHARS=120000
# Run memory close/batch/digest on the HTTP thread (e.g. pytest on Windows; not for production)
# EDITR_INKBLOT_MEMORY_JOBS_INLINE=1

# Beta stack: openai | gemini (single toggle; per-request `provider` on analyze/chat can override when valid)
LLM_PROVIDER=gemini

# OpenAI (when LLM_PROVIDER=openai or for mixed per-stage overrides in code)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_PRO_MODEL=gpt-5.4

# Gemini / Google AI (when LLM_PROVIDER=gemini). Use GEMINI_API_KEY or GOOGLE_API_KEY.
GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3-flash
GEMINI_FAST_MODEL=gemini-3-flash
GEMINI_PRO_MODEL=gemini-3.1-pro-preview

# Internal: extra mediator / dialectic LLM steps before editor judgment (off | review | deep). Increases latency/cost when not off.
EDITR_DIALECTIC_DEPTH=deep

# Optional tuning
# LLM_TEMPERATURE=0
# QUICK_COACH_OOB_RATIO=0.3
# QUICK_COACH_OOB_MIN_CHARS=120
# QUICK_COACH_OOB_MAX_CHARS=1200
