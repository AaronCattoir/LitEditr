# Copy to .env and fill in API keys. Server-side only; the web UI does not read these.

EDITR_DB_PATH=editr.sqlite
# Optional: directory with a Vite/React build (index.html + assets). Unset = API-only.
# EDITR_STATIC_DIR=

# Beta stack: openai | gemini (single toggle; per-request `provider` on analyze/chat can override when valid)
LLM_PROVIDER=gemini

# OpenAI (when LLM_PROVIDER=openai or for mixed per-stage overrides in code)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_PRO_MODEL=gpt-5.4

# Gemini / Google AI (when LLM_PROVIDER=gemini). Use GEMINI_API_KEY or GOOGLE_API_KEY.
GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-3.1-pro

# Optional tuning
# LLM_TEMPERATURE=0
# QUICK_COACH_OOB_RATIO=0.3
# QUICK_COACH_OOB_MIN_CHARS=120
# QUICK_COACH_OOB_MAX_CHARS=1200
