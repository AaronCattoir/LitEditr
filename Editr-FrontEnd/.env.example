# Leave empty to use same-origin / Vite dev proxy (see vite.config.ts proxy /v1 -> http://127.0.0.1:8000).
VITE_API_BASE_URL=

# Set to true for offline mock coaching / Submit All (no backend).
VITE_USE_MOCK_API=false

# Section split marker used for manuscript save/reload and paste auto-split.
# Default is "~". A section break is a line containing only this marker.
VITE_SCENE_SPLIT_MARKER=~

# Legacy fallback: when true, reload/import may split sections on blank lines.
# Keep false to avoid automatic re-chunking on plain line breaks.
VITE_AUTO_SPLIT_BLANK_LINES=false
